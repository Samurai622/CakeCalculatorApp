<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CakeCalculatorApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="CakeCalculatorApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Калькулятор Тортів (ООП)"
        Width="950" Height="650">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Відкрити базу..." HotKey="Ctrl+O" InputGesture="Ctrl+O" Click="OpenFile_Click" />
                <MenuItem Header="_Зберегти" HotKey="Ctrl+S" InputGesture="Ctrl+S" Click="SaveFile_Click" />
                <Separator/>
                <MenuItem Header="_Завантажити з хмари" Command="{Binding SyncFromCloudCommand}" ToolTip.Tip="Отримати найновіший рецепт" Margin="0,0,5,0"/>
                <MenuItem Header="_Відправити в хмару" Command="{Binding UploadToCloudCommand}" ToolTip.Tip="Поділитися рецептом"/>
                <Separator/>
                <MenuItem Header="Вихід" HotKey="Alt+F4" InputGesture="Alt+F4" />
            </MenuItem>
            <MenuItem Header="_Дані">
                <MenuItem Header="Сортувати (за вагою)" Command="{Binding SortByWeightCommand}"/>
                <MenuItem Header="Фільтрувати (тільки тісто)" Command="{Binding FilterVolumeOnlyCommand}"/>
            </MenuItem>
            <MenuItem Header="_Довідка">
                <MenuItem Header="_Про програму" HotKey="F1" InputGesture="F1" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#1AFFFFFF" Margin="5">
            <Button Content="📂 Завантажити" ToolTip.Tip="Відкрити локальну базу рецептів" Margin="0,0,5,0" Click="OpenFile_Click"/>
            <Button Content="💾 Зберегти" ToolTip.Tip="Зберегти поточні рецепти" Margin="0,0,5,0" Click="SaveFile_Click"/>
            <Separator Width="2" Background="Gray" Margin="5,0"/>
            <Button Content="☁️ Supabase Sync" ToolTip.Tip="Синхронізація з хмарною спільнотою" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Background="#007ACC" Padding="10,5">
            <TextBlock Text="{Binding Greeting}" Foreground="White" FontWeight="Bold" />
        </Border>
        
        <Grid ColumnDefinitions="*,*">
            
            <Grid Grid.Column="0" RowDefinitions="Auto, Auto, Auto, *, Auto" Margin="10,10,20,10">
                <TextBlock Grid.Row="0" Text="🎂 Оригінальний рецепт" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                
                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Форма:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding AvailableShapes}" SelectedItem="{Binding SelectedOriginalShape}" Width="150"/>
                    </StackPanel>
                    
                    <Grid ColumnDefinitions="Auto, *, Auto, *" Margin="0,5,0,0">
                        <TextBlock Grid.Column="0" Text="{Binding OriginalParam1Label}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" Text="{Binding OriginalParam1}" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="Висота (см):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="3" Text="{Binding OriginalHeight}"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto, *" Margin="0,5,0,0" IsVisible="{Binding IsOriginalWidthVisible}">
                        <TextBlock Grid.Column="0" Text="Ширина (см):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" Text="{Binding OriginalParam2}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto, *" Margin="0,5,0,0">
                        <TextBlock Grid.Column="0" Text="Кількість коржів:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" Text="{Binding OriginalLayers}" />
                    </Grid>
                </StackPanel>

                <Border Grid.Row="2" Background="#1AFFFFFF" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Додати інгредієнт:" FontWeight="Bold" Margin="0,0,0,5"/>
                        
                        <Grid ColumnDefinitions="*, 80, 70" Margin="0,0,0,5">
                            <TextBox Grid.Column="0" Watermark="Назва (напр. Яйця)" Text="{Binding NewIngredientName}" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="1" Watermark="Кіл-ть" Text="{Binding NewIngredientWeight}" Margin="0,0,5,0"/>
                            <ComboBox Grid.Column="2" ItemsSource="{Binding AvailableUnits}" SelectedItem="{Binding SelectedUnit}" HorizontalAlignment="Stretch"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,10">
                            <ComboBox Grid.Column="0" ItemsSource="{Binding IngredientTypes}" SelectedItem="{Binding SelectedIngredientType}" HorizontalAlignment="Stretch" Margin="0,0,5,0"/>
                            
                            <Button Grid.Column="1" Content="💾 Зберегти зміни" Command="{Binding UpdateIngredientCommand}" IsVisible="{Binding HasSelectedIngredient}" Background="#FFC107" Foreground="Black" FontWeight="Bold" Margin="0,0,5,0"/>
                            
                            <Button Grid.Column="2" Content="➕ Додати" Command="{Binding AddIngredientCommand}" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="5">
                            
                            <Button Content="✏️ Редагувати" Command="{Binding LoadForEditCommand}" IsVisible="{Binding HasSelectedIngredient}" Background="#17A2B8" Foreground="White"/>
                            
                            <Button Content="🗑 Видалити" Command="{Binding DeleteSelectedIngredientCommand}" IsVisible="{Binding HasSelectedIngredient}" Background="#6C757D" Foreground="White"/>
                            
                            <Button Content="❌ Очистити" Command="{Binding ClearIngredientsCommand}" IsVisible="{Binding HasIngredients}" Background="#DC3545" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="3" ItemsSource="{Binding OriginalIngredients}" SelectedItem="{Binding SelectedOriginalIngredient}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderThickness="1" BorderBrush="Gray">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Інгредієнт" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding IngredientTypeLabel}" Width="120"/>
                        <DataGridTextColumn Header="Кіл-ть" Binding="{Binding Weight}" Width="60"/>
                        <DataGridTextColumn Header="Од." Binding="{Binding Unit}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="4" Text="{Binding OriginalTotal, StringFormat='Підсумок: {0} од.'}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right" Margin="0,5,0,0"/>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto, Auto, Auto, *, Auto" Margin="10">
                <TextBlock Grid.Row="0" Text="✨ Новий торт" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                
                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Нова форма:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding AvailableShapes}" SelectedItem="{Binding SelectedTargetShape}" Width="150"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto, *, Auto, *" Margin="0,5,0,0">
                        <TextBlock Grid.Column="0" Text="{Binding TargetParam1Label}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" Text="{Binding TargetParam1}" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="Висота (см):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="3" Text="{Binding TargetHeight}"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto, *" Margin="0,5,0,0" IsVisible="{Binding IsTargetWidthVisible}">
                        <TextBlock Grid.Column="0" Text="Ширина (см):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" Text="{Binding TargetParam2}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto, *" Margin="0,5,0,0">
                        <TextBlock Grid.Column="0" Text="Кількість коржів:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" Text="{Binding TargetLayers}" />
                    </Grid>
                    
                    <CheckBox Content="Виключити глазур/покриття?" IsChecked="{Binding ExcludeSurface}" Margin="0,10,0,0"/>
                </StackPanel>

                <Button Grid.Row="2" Content="🔄 Розрахувати новий рецепт" Command="{Binding CalculateCommand}" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" 
                        Background="#28A745" Foreground="White" FontWeight="Bold" FontSize="16" Padding="10" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="3" ItemsSource="{Binding RecalculatedIngredients}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderThickness="1" BorderBrush="Gray">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Інгредієнт" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding IngredientTypeLabel}" Width="120"/>
                        <DataGridTextColumn Header="Кіл-ть" Binding="{Binding Weight}" Width="60"/>
                        <DataGridTextColumn Header="Од." Binding="{Binding Unit}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="4" Text="{Binding RecalculatedTotal, StringFormat='Підсумок: {0} од.'}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right" Margin="0,5,0,0"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>