<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CakeCalculatorApp.App"
             RequestedThemeVariant="Light">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#F2B5D4"/> 
            <Setter Property="Foreground" Value="#5C4033"/> 
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E599BC"/> 
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#D6E5D8"/> 
            <Setter Property="Foreground" Value="#2E4031"/>
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#FFB3B3"/> 
            <Setter Property="Foreground" Value="#591C1C"/>
        </Style>

        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#8C6B5D"/> 
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="BorderBrush" Value="#EADDCB"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 4 10 0 #1A000000"/> 
        </Style>

        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#EADDCB"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#EADDCB"/>
        </Style>
        
        <Style Selector="DataGrid">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#EADDCB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FCF9F2"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#F2E6D8"/> 
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5C4033"/>
        </Style>
    </Application.Styles>
</Application>