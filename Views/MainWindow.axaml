<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CakeCalculatorApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CakeCalculatorApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Калькулятор Тортів (ООП)"
        Width="900" Height="600">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#000000ff">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Відкрити базу..." HotKey="Ctrl+O" InputGesture="Ctrl+O" Click="OpenFile_Click" />
                <MenuItem Header="_Зберегти" HotKey="Ctrl+S" InputGesture="Ctrl+S" Click="SaveFile_click" />
                <Separator/>
                <MenuItem Header="Вихід" HotKey="Alt+F4" InputGesture="Alt+F4" />
            </MenuItem>
            <MenuItem Header="_Дані">
                <MenuItem Header="Сортувати (за вагою)" />
                <MenuItem Header="Фільтрувати (тільки тісто)" />
            </MenuItem>
            <MenuItem Header="_Довідка">
                <MenuItem Header="_Про програму" HotKey="F1" InputGesture="F1" />
            </MenuItem>
        </Menu>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#000000ff" Margin="5">
            <Button Content="📂 Завантажити" ToolTip.Tip="Відкрити локальну базу рецептів" Margin="0,0,5,0" />
            <Button Content="💾 Зберегти" ToolTip.Tip="Зберегти поточні рецепти" Margin="0,0,5,0" />
            <Separator Width="2" Background="Gray" Margin="5,0"/>
            <Button Content="☁️ Supabase Sync" ToolTip.Tip="Синхронізація з хмарною спільнотою" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Background="#007ACC" Padding="10,5">
            <TextBlock Text="{Binding Greeting}" Foreground="White" FontWeight="Bold" />
        </Border>
        
        <Grid ColumnDefinitions="*,*">
            
            <Grid Grid.Column="0" RowDefinitions="Auto, Auto, *" Margin="10">
                <TextBlock Grid.Row="0" Text="🎂 Оригінальний рецепт (Торт_0)" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                
                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="Форма: Круглий (Циліндр)" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="Auto, *, Auto, *" Margin="0,5,0,0">
                        <TextBlock Grid.Column="0" Text="Радіус (см):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" Text="{Binding OriginalRadius}" Margin="0,0,15,0"/>
                        <TextBlock Grid.Column="2" Text="Висота (см):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="3" Text="{Binding OriginalHeight}"/>
                    </Grid>
                </StackPanel>

                <DataGrid Grid.Row="2" ItemsSource="{Binding OriginalIngredients}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderThickness="1" BorderBrush="Gray">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Назва інгредієнта" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Вага" Binding="{Binding Weight}" Width="80"/>
                        <DataGridTextColumn Header="Од." Binding="{Binding Unit}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto, Auto, Auto, *" Margin="10">
                <TextBlock Grid.Row="0" Text="✨ Перерахунок (Торт_1)" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                
                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="Нова форма: Прямокутний" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="*,*,*" Margin="0,5,0,0">
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Довжина:"/>
                            <TextBox Text="{Binding TargetLength}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,5,0">
                            <TextBlock Text="Ширина:"/>
                            <TextBox Text="{Binding TargetWidth}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Висота:"/>
                            <TextBox Text="{Binding TargetHeight}"/>
                        </StackPanel>
                    </Grid>
                    <CheckBox Content="Виключити глазур/покриття?" IsChecked="{Binding ExcludeSurface}" Margin="0,10,0,0"/>
                </StackPanel>

                <Button Grid.Row="2" Content="🔄 Розрахувати новий рецепт" Command="{Binding CalculateCommand}" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" 
                        Background="#28A745" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="3" ItemsSource="{Binding RecalculatedIngredients}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderThickness="1" BorderBrush="Gray">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Назва інгредієнта" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Вага" Binding="{Binding Weight}" Width="80"/>
                        <DataGridTextColumn Header="Од." Binding="{Binding Unit}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
        <Grid>
            
        </Grid>
    </DockPanel>
</Window>